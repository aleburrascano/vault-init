#!/usr/bin/env node
// vaultkit search MCP launcher. Single source of truth — copied verbatim into
// `~/.vaultkit/search-launcher.js` by `vaultkit setup` and registered as the
// `vaultkit-search` MCP server in `~/.claude.json`.
//
// Security model: at MCP registration time, vaultkit pins this file's
// SHA-256 by passing --expected-sha256=<hex> as an arg. On every Claude Code
// session start, the launcher re-verifies its own hash before running. Any
// in-place tampering surfaces as a clear refuse-to-start, pointing the user
// at `vaultkit setup` to re-pin or repair.
//
// Mirrors the pattern of `mcp-start.js.tmpl` (the per-vault launcher,
// pinned by ADR-0001) — same threat model, same defense.
//
// Unlike the per-vault launcher, this one does NOT run a git fetch/merge:
// the search index is local state at `~/.vaultkit-search.db`, not a git repo.
// All it does is verify itself, then `npx vaultkit-search-server`.
const { spawnSync } = require('child_process');
const crypto = require('crypto');
const fs = require('fs');
const path = require('path');

const expectedFlag = process.argv.find(
  (a) => typeof a === 'string' && a.startsWith('--expected-sha256='),
);
const EXPECTED = expectedFlag ? expectedFlag.slice('--expected-sha256='.length) : null;

function sha256(file) {
  return crypto.createHash('sha256').update(fs.readFileSync(file)).digest('hex');
}

function abort(lines) {
  for (const l of lines) process.stderr.write('[vaultkit-search] ' + l + '\n');
  process.exit(1);
}

// 1. Self-verify (same shape as mcp-start.js.tmpl).
if (EXPECTED) {
  const actual = sha256(__filename);
  if (actual !== EXPECTED) {
    abort([
      'Search launcher SHA-256 mismatch — refusing to start.',
      '  Expected: ' + EXPECTED,
      '  Actual:   ' + actual,
      'Inspect: cat "' + __filename + '"',
      'Re-trust: vaultkit setup',
    ]);
  }
} else {
  process.stderr.write(
    '[vaultkit-search] Warning: registered without a pinned SHA-256.\n' +
      '[vaultkit-search] Run `vaultkit setup` to enable launcher verification.\n',
  );
}

// 2. Windows: npx ships as npx.cmd which CreateProcess rejects. Prepend
// node's directory to PATH and use shell:true so cmd.exe resolves the .cmd
// shim. Same workaround as mcp-start.js.tmpl.
if (process.platform === 'win32') {
  const nodeDir = path.dirname(process.execPath);
  process.env.PATH = nodeDir + ';' + (process.env.PATH || '');
}

// 3. Spawn the actual MCP server. `vaultkit-search-server` is a `bin` entry
// in vaultkit's package.json — already installed alongside the user's
// vaultkit CLI, so no `-y` (auto-install) flag is needed.
const r = spawnSync('npx', ['vaultkit-search-server'], {
  stdio: 'inherit',
  shell: process.platform === 'win32',
});
if (r.error) {
  abort([
    'Failed to start vaultkit-search-server: ' + r.error.message,
    'Check your Node.js installation and `npm i -g @aleburrascano/vaultkit`.',
  ]);
}
process.exit(r.status === null || r.status === undefined ? 1 : r.status);
